# Enable AMDGPU on rk35xx vendor 6.1
CONFIG_DRM_AMDGPU=m
CONFIG_DRM_AMDGPU_USERPTR=y

# Required dependencies for userptr/HMM-backed memory management
CONFIG_HMM_MIRROR=y
CONFIG_ZONE_DEVICE=y
CONFIG_DEVICE_PRIVATE=y

# Keep TTM enabled as module and buddy allocator available
CONFIG_DRM_TTM=m
CONFIG_DRM_BUDDY=y

# Explicitly pin workaround toggles introduced by this patchset
CONFIG_ARM64_ALIGNMENT_FIXUPS=y
CONFIG_ARM64_FORCE_PCIE_MMIO_DEVICE_MAPPINGS=y
CONFIG_DRM_FORCE_DMA_WRITE_COMBINED_MAPPINGS=y
