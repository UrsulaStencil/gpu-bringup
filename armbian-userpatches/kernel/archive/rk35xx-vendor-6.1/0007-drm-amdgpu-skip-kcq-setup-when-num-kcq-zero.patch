From a1d9bf833be8a0aef8c83f3ead2a3f8dc4d3f270 Mon Sep 17 00:00:00 2001
From: Codex <codex@openai.local>
Date: Fri, 13 Mar 2026 14:28:00 +0100
Subject: [PATCH] drm/amdgpu: skip KCQ setup when num_kcq=0

For RK3588 eGPU bring-up we use `amdgpu.num_kcq=0` to isolate the graphics
bring-up path from compute queue setup. The current code still executes KCQ
setup and KIQ ring testing even when zero compute queues are requested,
which defeats that knob and still hard-fails probe on KIQ timeout.

Treat zero compute rings as an explicit request to skip KCQ setup/teardown.
This keeps default behavior unchanged and only affects configurations that
already requested `num_kcq=0`.

---
 drivers/gpu/drm/amd/amdgpu/amdgpu_gfx.c | 8 ++++++++
 1 file changed, 8 insertions(+)

diff --git a/drivers/gpu/drm/amd/amdgpu/amdgpu_gfx.c b/drivers/gpu/drm/amd/amdgpu/amdgpu_gfx.c
index 311218722920..bc0c6f6d0176 100644
--- a/drivers/gpu/drm/amd/amdgpu/amdgpu_gfx.c
+++ b/drivers/gpu/drm/amd/amdgpu/amdgpu_gfx.c
@@ -470,6 +470,9 @@ int amdgpu_gfx_disable_kcq(struct amdgpu_device *adev)
 	if (!kiq->pmf || !kiq->pmf->kiq_unmap_queues)
 		return -EINVAL;
 
+	if (!adev->gfx.num_compute_rings)
+		return 0;
+
 	spin_lock(&adev->gfx.kiq.ring_lock);
 	if (amdgpu_ring_alloc(kiq_ring, kiq->pmf->unmap_queues_size *
 					adev->gfx.num_compute_rings)) {
@@ -511,6 +514,11 @@ int amdgpu_gfx_enable_kcq(struct amdgpu_device *adev)
 	if (!kiq->pmf || !kiq->pmf->kiq_map_queues || !kiq->pmf->kiq_set_resources)
 		return -EINVAL;
 
+	if (!adev->gfx.num_compute_rings) {
+		DRM_INFO("no kernel compute queues configured; skipping KCQ setup\n");
+		return 0;
+	}
+
 	for (i = 0; i < AMDGPU_MAX_COMPUTE_QUEUES; ++i) {
 		if (!test_bit(i, adev->gfx.mec.queue_bitmap))
 			continue;
-- 
