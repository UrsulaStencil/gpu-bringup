+__attribute__((always_inline)) inline int get_data(int size, uint8_t* data, void* addr){
+	int r = 0;
+	int addrIt = 0;
+
+	// with the fixed size loops, the compiler should be able to unroll them
+	// this should mean a lot less branching
+	uint8_t val;
+	switch(size){
