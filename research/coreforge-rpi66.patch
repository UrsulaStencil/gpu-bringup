+			if((r=get_user( val, (uint8_t __user *)addr))){
+				printk("Failed to read data at 0x%px\n", addr);
+				return r;
+			}
+			*(data + addrIt) = val;
+			addrIt++;
+			addr++;
+		}
+		// fall through
+	case 2:
+		if((r=get_user( val, (uint8_t __user *)addr))){
+			printk("Failed to read data at 0x%px\n", addr);
+			return r;
+		}
+		*(data + addrIt) = val;
+		addrIt++;
+		addr++;
+		// fall through
+	case 1:
+		if((r=get_user( val, (uint8_t __user *)addr))){
+			printk("Failed to read data at 0x%px\n", addr);
+			return r;
+		}
+		*(data + addrIt) = val;
+		addrIt++;
