+	dev_info(adev->dev,
+		 "gfx cp load: %s CP_STAT=0x%08x CP_ME_CNTL=0x%08x PFP_OP=0x%08x CE_OP=0x%08x ME_OP=0x%08x PFP_BASE=0x%08x:%08x CE_BASE=0x%08x:%08x ME_BASE=0x%08x:%08x PFP_UCODE=0x%08x CE_UCODE=0x%08x ME_UCODE=0x%08x CPG_PSP_DEBUG=0x%08x CPC_PSP_DEBUG=0x%08x RLC_SAFE_MODE=0x%08x RLC_CP_SCHED=0x%08x PA_SC_TILE=0x%08x\n",
+		 stage,
+		 RREG32_SOC15(GC, 0, mmCP_STAT),
+		 RREG32_SOC15(GC, 0, mmCP_ME_CNTL),
+		 RREG32_SOC15(GC, 0, mmCP_PFP_IC_OP_CNTL),
+		 RREG32_SOC15(GC, 0, mmCP_CE_IC_OP_CNTL),
+		 RREG32_SOC15(GC, 0, mmCP_ME_IC_OP_CNTL),
