+static int gfx_v10_0_cp_gfx_create_fw_bo(struct amdgpu_device *adev,
+					 const char *name,
+					 unsigned long size,
+					 struct amdgpu_bo **bo_ptr,
+					 u64 *gpu_addr,
+					 void **cpu_addr)
+{
+	u32 domain = AMDGPU_GEM_DOMAIN_GTT;
+	int r;
+
+#if defined(CONFIG_ARM64)
+	if (adev->firmware.load_type == AMDGPU_FW_LOAD_DIRECT) {
+		domain = AMDGPU_GEM_DOMAIN_VRAM;
+		r = amdgpu_bo_create_reserved(adev, size, PAGE_SIZE, domain,
+					      bo_ptr, gpu_addr, cpu_addr);
+		if (!r) {
+			dev_info(adev->dev,
+				 "gfx cp load: using VRAM-backed %s fw bo gpu_addr=0x%llx size=0x%lx\n",
+				 name, (unsigned long long)*gpu_addr, size);
+			return 0;
+		}
+
+		dev_warn(adev->dev,
+			 "gfx cp load: VRAM-backed %s fw bo alloc failed (%d), falling back to GTT\n",
+			 name, r);
+		domain = AMDGPU_GEM_DOMAIN_GTT;
+	}
+#endif
+
+	r = amdgpu_bo_create_reserved(adev, size, PAGE_SIZE, domain,
+				      bo_ptr, gpu_addr, cpu_addr);
+	if (!r && adev->firmware.load_type == AMDGPU_FW_LOAD_DIRECT)
+		dev_info(adev->dev,
+			 "gfx cp load: using GTT-backed %s fw bo gpu_addr=0x%llx size=0x%lx\n",
+			 name, (unsigned long long)*gpu_addr, size);
+
+	return r;
+}
