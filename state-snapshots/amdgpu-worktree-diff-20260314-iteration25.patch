+static bool psp_get_natural_tmr_offset(struct psp_context *psp,
+				       uint32_t tmr_size,
+				       uint64_t *tmr_offset,
+				       uint64_t *top_limit)
+{
+	struct amdgpu_device *adev = psp->adev;
+	struct psp_memory_training_context *ctx = &psp->mem_train_ctx;
+	uint64_t limit = adev->gmc.real_vram_size;
+
+	if (!tmr_size)
+		return false;
+
+	if (adev->mman.fw_reserved_memory)
+		limit -= amdgpu_bo_size(adev->mman.fw_reserved_memory);
+
+	if (ctx->init == PSP_MEM_TRAIN_RESERVE_SUCCESS &&
+	    ctx->c2p_bo &&
+	    ctx->c2p_train_data_offset &&
+	    ctx->c2p_train_data_offset < limit)
+		limit = ctx->c2p_train_data_offset;
+
+	if (limit <= tmr_size)
+		return false;
+
+	*top_limit = limit;
+	*tmr_offset = rounddown(limit - tmr_size, (uint64_t)tmr_size);
+
+	return (*tmr_offset + tmr_size) <= limit;
+}
