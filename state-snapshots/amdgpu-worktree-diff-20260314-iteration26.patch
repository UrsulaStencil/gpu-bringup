+		dev_info(adev->dev,
+			 "psp %s: cmd=%s(0x%x) buf_mc=0x%llx buf_size=0x%x system_pa=0x%llx flags=0x%x resp{status=0x%x fw=0x%08x:%08x tmr=0x%x}\n",
+			 stage, psp_gfx_cmd_name(cmd->cmd_id), cmd->cmd_id,
+			 (unsigned long long)(((u64)cmd->cmd.cmd_setup_tmr.buf_phy_addr_hi << 32) |
+					      cmd->cmd.cmd_setup_tmr.buf_phy_addr_lo),
+			 cmd->cmd.cmd_setup_tmr.buf_size,
+			 (unsigned long long)(((u64)cmd->cmd.cmd_setup_tmr.system_phy_addr_hi << 32) |
+					      cmd->cmd.cmd_setup_tmr.system_phy_addr_lo),
+			 cmd->cmd.cmd_setup_tmr.tmr_flags,
+			 cmd->resp.status,
+			 cmd->resp.fw_addr_hi,
+			 cmd->resp.fw_addr_lo,
+			 cmd->resp.tmr_size);
+		break;
+	case GFX_CMD_ID_LOAD_ASD:
+	case GFX_CMD_ID_LOAD_TA:
+		dev_info(adev->dev,
+			 "psp %s: cmd=%s(0x%x) app_mc=0x%llx app_len=0x%x shared_mc=0x%llx shared_len=0x%x resp{status=0x%x fw=0x%08x:%08x tmr=0x%x}\n",
+			 stage, psp_gfx_cmd_name(cmd->cmd_id), cmd->cmd_id,
+			 (unsigned long long)(((u64)cmd->cmd.cmd_load_ta.app_phy_addr_hi << 32) |
+					      cmd->cmd.cmd_load_ta.app_phy_addr_lo),
+			 cmd->cmd.cmd_load_ta.app_len,
+			 (unsigned long long)(((u64)cmd->cmd.cmd_load_ta.cmd_buf_phy_addr_hi << 32) |
+					      cmd->cmd.cmd_load_ta.cmd_buf_phy_addr_lo),
+			 cmd->cmd.cmd_load_ta.cmd_buf_len,
+			 cmd->resp.status,
+			 cmd->resp.fw_addr_hi,
+			 cmd->resp.fw_addr_lo,
+			 cmd->resp.tmr_size);
+		break;
+	default:
+		dev_info(adev->dev,
+			 "psp %s: cmd=%s(0x%x) resp{status=0x%x fw=0x%08x:%08x tmr=0x%x}\n",
+			 stage, psp_gfx_cmd_name(cmd->cmd_id), cmd->cmd_id,
+			 cmd->resp.status,
+			 cmd->resp.fw_addr_hi,
+			 cmd->resp.fw_addr_lo,
+			 cmd->resp.tmr_size);
+		break;
+	}
