+static void psp_mark_cmd_resp_pending(struct psp_gfx_cmd_resp *cmd)
+{
+	u32 *dw = (u32 *)&cmd->resp;
+	int i;
+
+	for (i = 0; i < ARRAY_SIZE(cmd->resp.reserved); i++)
+		dw[i] = PSP_CMD_RESP_SENTINEL;
+}
+
+static bool psp_cmd_resp_written(const struct psp_gfx_cmd_resp *cmd)
+{
+	const u32 *dw = (const u32 *)&cmd->resp;
+	int i;
+
+	for (i = 0; i < ARRAY_SIZE(cmd->resp.reserved); i++) {
+		if (dw[i] != PSP_CMD_RESP_SENTINEL)
+			return true;
+	}
+
+	return false;
+}
