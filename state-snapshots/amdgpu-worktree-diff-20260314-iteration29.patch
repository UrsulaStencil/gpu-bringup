+static void psp_log_boot_bufs(struct psp_context *psp, const char *stage,
+			      const struct psp_gfx_cmd_resp *cmd)
+{
+	struct amdgpu_device *adev = psp->adev;
+	struct psp_ring *ring = &psp->km_ring;
