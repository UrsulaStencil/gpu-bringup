+	unsigned long cmd_size = psp->cmd_buf_bo ? amdgpu_bo_size(psp->cmd_buf_bo) : 0;
+	unsigned long fence_size = psp->fence_buf_bo ? amdgpu_bo_size(psp->fence_buf_bo) : 0;
+	unsigned long tmr_size = psp->tmr_bo ? amdgpu_bo_size(psp->tmr_bo) : 0;
+
+	dev_info(adev->dev,
+		 "psp %s: fw_pri_mc=0x%llx cmd_mc=0x%llx fence_mc=0x%llx ring_mc=0x%llx tmr_mc=0x%llx sizes fw=0x%lx cmd=0x%lx fence=0x%lx ring=0x%x tmr=0x%lx\n",
+		 stage,
+		 (unsigned long long)fw_pri_mc,
+		 (unsigned long long)cmd_mc,
+		 (unsigned long long)fence_mc,
+		 (unsigned long long)ring_mc,
+		 (unsigned long long)tmr_mc,
+		 fw_pri_size, cmd_size, fence_size, ring->ring_size, tmr_size);
+
+	if (!cmd)
+		return;
+
+	switch (cmd->cmd_id) {
+	case GFX_CMD_ID_LOAD_TOC:
+		dev_info(adev->dev,
+			 "psp %s: cmd=%s(0x%x) toc_mc=0x%llx toc_size=0x%x resp{status=0x%x fw=0x%08x:%08x tmr=0x%x}\n",
+			 stage, psp_gfx_cmd_name(cmd->cmd_id), cmd->cmd_id,
+			 (unsigned long long)(((u64)cmd->cmd.cmd_load_toc.toc_phy_addr_hi << 32) |
+					      cmd->cmd.cmd_load_toc.toc_phy_addr_lo),
