+static bool psp_v11_0_invalid_mailbox_read(struct psp_context *psp,
+					   uint32_t reg_index, uint32_t val)
+{
+	struct amdgpu_device *adev = psp->adev;
+
+#if defined(CONFIG_ARM64)
+	if (adev->ip_versions[MP0_HWIP][0] != IP_VERSION(11, 0, 13))
+		return false;
+
+	if (val != 0xffffffff)
+		return false;
+
+	if (reg_index == SOC15_REG_OFFSET(MP0, 0, mmMP0_SMN_C2PMSG_33) ||
+	    reg_index == SOC15_REG_OFFSET(MP0, 0, mmMP0_SMN_C2PMSG_35) ||
+	    reg_index == SOC15_REG_OFFSET(MP0, 0, mmMP0_SMN_C2PMSG_36) ||
+	    reg_index == SOC15_REG_OFFSET(MP0, 0, mmMP0_SMN_C2PMSG_64) ||
+	    reg_index == SOC15_REG_OFFSET(MP0, 0, mmMP0_SMN_C2PMSG_65) ||
+	    reg_index == SOC15_REG_OFFSET(MP0, 0, mmMP0_SMN_C2PMSG_66) ||
+	    reg_index == SOC15_REG_OFFSET(MP0, 0, mmMP0_SMN_C2PMSG_69) ||
+	    reg_index == SOC15_REG_OFFSET(MP0, 0, mmMP0_SMN_C2PMSG_70) ||
+	    reg_index == SOC15_REG_OFFSET(MP0, 0, mmMP0_SMN_C2PMSG_71) ||
+	    reg_index == SOC15_REG_OFFSET(MP0, 0, mmMP0_SMN_C2PMSG_81) ||
+	    reg_index == SOC15_REG_OFFSET(MP0, 0, mmMP0_SMN_C2PMSG_101) ||
+	    reg_index == SOC15_REG_OFFSET(MP0, 0, mmMP0_SMN_C2PMSG_102) ||
+	    reg_index == SOC15_REG_OFFSET(MP0, 0, mmMP0_SMN_C2PMSG_103))
+		return true;
+
+	return false;
+#else
+	return false;
+#endif
+}
