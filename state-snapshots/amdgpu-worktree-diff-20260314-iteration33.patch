+static void gfx_v10_0_cp_gfx_prepare_for_load(struct amdgpu_device *adev)
+{
+	u16 pci_cmd = 0;
+	u32 cp_stat;
+	u32 grbm_status;
+	u32 grbm_status2;
+	u32 grbm_gfx_cntl;
+	u32 grbm_gfx_index;
+
+	pci_read_config_word(adev->pdev, PCI_COMMAND, &pci_cmd);
+	if (!(pci_cmd & PCI_COMMAND_MASTER)) {
+		dev_warn(adev->dev,
+			 "gfx cp load: PCI_COMMAND=0x%04x missing bus mastering, forcing enable\n",
+			 pci_cmd);
+		pci_set_master(adev->pdev);
+		pci_read_config_word(adev->pdev, PCI_COMMAND, &pci_cmd);
+			dev_info(adev->dev,
+				 "gfx cp load: PCI_COMMAND after pci_set_master=0x%04x\n",
+				 pci_cmd);
+	}
+
+	gfx_v10_0_log_cp_gfx_direct_state(adev, "pre-disable-gpa");
+	gfx_v10_0_disable_gpa_mode(adev);
+	gfx_v10_0_log_cp_gfx_direct_state(adev, "post-disable-gpa");
+
+	gfx_v10_0_cp_gfx_enable(adev, false);
+	cp_stat = RREG32_SOC15(GC, 0, mmCP_STAT);
+	grbm_status = RREG32_SOC15(GC, 0, mmGRBM_STATUS);
+	grbm_status2 = RREG32_SOC15(GC, 0, mmGRBM_STATUS2);
+
+	if (adev->firmware.load_type == AMDGPU_FW_LOAD_DIRECT) {
+		dev_info(adev->dev,
+			 "gfx cp load: forcing local soft reset before direct ucode load (pre CP_STAT=0x%08x GRBM_STATUS=0x%08x GRBM_STATUS2=0x%08x)\n",
+			 cp_stat, grbm_status, grbm_status2);
+		gfx_v10_0_soft_reset(adev);
+		mutex_lock(&adev->grbm_idx_mutex);
+			gfx_v10_0_select_se_sh(adev, 0xffffffff, 0xffffffff, 0xffffffff);
+			mutex_unlock(&adev->grbm_idx_mutex);
+			mutex_lock(&adev->srbm_mutex);
+			gfx_v10_0_cp_gfx_switch_pipe(adev, PIPE_ID0);
+			mutex_unlock(&adev->srbm_mutex);
+			gfx_v10_0_disable_gpa_mode(adev);
+			gfx_v10_0_cp_gfx_enable(adev, false);
+			cp_stat = RREG32_SOC15(GC, 0, mmCP_STAT);
+			grbm_status = RREG32_SOC15(GC, 0, mmGRBM_STATUS);
+			grbm_status2 = RREG32_SOC15(GC, 0, mmGRBM_STATUS2);
+			grbm_gfx_cntl = RREG32_SOC15(GC, 0, mmGRBM_GFX_CNTL);
+			grbm_gfx_index = RREG32_SOC15(GC, 0, mmGRBM_GFX_INDEX);
+			dev_info(adev->dev,
+				 "gfx cp load: post-forced-soft-reset state CP_STAT=0x%08x GRBM_STATUS=0x%08x GRBM_STATUS2=0x%08x GRBM_GFX_CNTL=0x%08x GRBM_GFX_INDEX=0x%08x\n",
+				 cp_stat, grbm_status, grbm_status2,
+				 grbm_gfx_cntl, grbm_gfx_index);
+			gfx_v10_0_log_cp_gfx_direct_state(adev, "post-soft-reset");
+			return;
+		}
+
+	if (!cp_stat)
+		return;
+
+	dev_warn(adev->dev,
+		 "gfx cp load: CP still busy after halt (CP_STAT=0x%08x GRBM_STATUS=0x%08x GRBM_STATUS2=0x%08x), attempting local soft reset\n",
+		 cp_stat, grbm_status, grbm_status2);
+
+	gfx_v10_0_soft_reset(adev);
+	gfx_v10_0_cp_gfx_enable(adev, false);
+	cp_stat = RREG32_SOC15(GC, 0, mmCP_STAT);
+	grbm_status = RREG32_SOC15(GC, 0, mmGRBM_STATUS);
+	grbm_status2 = RREG32_SOC15(GC, 0, mmGRBM_STATUS2);
+	dev_info(adev->dev,
+		 "gfx cp load: post-soft-reset state CP_STAT=0x%08x GRBM_STATUS=0x%08x GRBM_STATUS2=0x%08x\n",
+		 cp_stat, grbm_status, grbm_status2);
+}
