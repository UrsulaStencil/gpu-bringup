+static bool amdgpu_read_bios_from_file(struct amdgpu_device *adev)
+{
+	const struct firmware *fw;
+	char fw_name[64];
+	int r;
+
+	snprintf(fw_name, sizeof(fw_name),
+		 "amdgpu/vbios-%04x-%04x-%04x-%04x.rom",
+		 adev->pdev->vendor, adev->pdev->device,
+		 adev->pdev->subsystem_vendor, adev->pdev->subsystem_device);
+
+	r = request_firmware_direct(&fw, fw_name, adev->dev);
+	if (r)
+		return false;
+
+	adev->bios = kmemdup(fw->data, fw->size, GFP_KERNEL);
+	if (!adev->bios) {
+		release_firmware(fw);
+		return false;
+	}
+
+	adev->bios_size = fw->size;
+	release_firmware(fw);
+
+	if (!check_atom_bios(adev->bios, adev->bios_size)) {
+		kfree(adev->bios);
+		adev->bios = NULL;
+		adev->bios_size = 0;
+		return false;
+	}
+
+	dev_info(adev->dev, "Using VBIOS fallback file %s\n", fw_name);
+	return true;
+}
+
 #ifdef CONFIG_ACPI
 /* ATRM is used to get the BIOS on the discrete cards in
  * dual-gpu systems.
@@ -463,6 +499,11 @@ bool amdgpu_get_bios(struct amdgpu_device *adev)
 		goto success;
 	}
 
+	if (amdgpu_read_bios_from_file(adev)) {
+		dev_info(adev->dev, "Fetched VBIOS from firmware file\n");
+		goto success;
+	}
+
 	dev_err(adev->dev, "Unable to locate a BIOS ROM\n");
 	return false;
 
